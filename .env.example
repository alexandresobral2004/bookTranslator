# ==============================================================================
# BookTranslator - Configurações de Ambiente
# ==============================================================================

# Diretórios de Dados (relativos ou absolutos)
MODEL_CACHE_DIR=./data/models
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
GLOSSARY_DIR=./data/glossary

# Configurações de Upload
MAX_FILE_MB=100

# Configurações do MarianMT
# Modelo padrão EN-PT: Helsinki-NLP/opus-mt-tc-big-en-pt
MARIAN_MODEL_NAME=Helsinki-NLP/opus-mt-tc-big-en-pt
CHUNK_SIZE_TOKENS=400
BATCH_SIZE=8

# Configurações de RAG / Glossário
GLOSSARY_FILE_NAME=glossary.csv
GLOSSARY_INDEX_DIR=glossary_index
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_K_NEIGHBORS=3

# Configurações de Pós-Edição OpenAI (Opcional)
USE_OPENAI_POSTEDIT=false
OPENAI_API_KEY=your_openai_api_key_here
QUALITY_THRESHOLD=0.6

# Cleanup e Retenção (em horas)
JOB_RETENTION_HOURS=24
